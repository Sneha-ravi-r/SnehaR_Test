expression getDataflowUUID =
		(dataflow as text) as text =>
		let
		    Source = Dataflow_UUID,
		    Filtered_Rows = Table.SelectRows(Source, each ( ([Environment] = Environment) and ([Workspace] = Workspace) and ([Dataflow] = dataflow))),
		    SingleRow = if Table.RowCount(Filtered_Rows) = 1 then Filtered_Rows else null
		in
		    Text.From(SingleRow{0}[UUID])
	lineageTag: 4c9a231c-1a58-4991-b6a8-24ed842a7d72

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Function

expression getWorkspaceUUID =
		() as text =>
		let
		    Source = Workspace_UUID,
		    _workspace = Text.Trim(Workspace),
		    _environment = Text.Trim(Environment),
		    Filtered_Rows = Table.SelectRows(Source, each ( ([Environment]=Environment) and ([Workspace] = Workspace))),
		    SingleRow = if Table.RowCount(Filtered_Rows) = 1 then Filtered_Rows else null
		in
		    SingleRow{0}[UUID]
	lineageTag: 20c04fb9-3f2a-4e6c-aea1-e56b6a13cc32

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Function

