	column 'Is Calibration Overdue' =
			
			IF (
			    'Maintenance_Schedule'[date_calculated_service_due] < TODAY() &&
			    ISBLANK('Maintenance_Schedule'[Date_Service_Completed]),
			    1,
			    0
			)
		formatString: 0
		lineageTag: 1678aa9b-72d4-4099-af0b-0f5f12da7f13
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Is Calibration Within 30 Days' =
			
			IF (
			    'Maintenance_Schedule'[date_calculated_service_due] >= TODAY() &&
			    'Maintenance_Schedule'[date_calculated_service_due] <= TODAY() + 30 &&
			    ISBLANK('Maintenance_Schedule'[Date_Service_Completed]),
