table Maintenance_Schedule
	lineageTag: 272cfa18-3ed2-41c9-bd99-8ccb2af2d3f3

	measure 'Cal Within 30 days' =
			
			CALCULATE(
			    COUNTROWS('Maintenance_Schedule'),
			    'Maintenance_Schedule'[date_calculated_service_due]>= TODAY(),
			    'Maintenance_Schedule'[date_calculated_service_due]<= TODAY() + 30,
			    'Service_Type'[is_type_calibration]= 1
			)
		formatString: 0
		lineageTag: d9e684a3-e093-4b31-b168-0976385c3303

	measure 'Cal Within 60 days' =
			
			CALCULATE(
			    COUNTROWS('Maintenance_Schedule'),
			    'Maintenance_Schedule'[date_calculated_service_due]> TODAY(),
			    'Maintenance_Schedule'[date_calculated_service_due]<= TODAY() + 60,
			    'Service_Type'[is_type_calibration]= 1
			)
		formatString: 0
		lineageTag: 89614799-843f-4dfb-90dd-1b64c85612c1

	measure 'Cal Within 90 days' =
			
			CALCULATE(
			    COUNTROWS('Maintenance_Schedule'),
			    'Maintenance_Schedule'[date_calculated_service_due]> TODAY() + 60,
			    'Maintenance_Schedule'[date_calculated_service_due]<= TODAY() + 90,
			    'Service_Type'[is_type_calibration]= 1
			)
		formatString: 0
		lineageTag: cf4f6302-2f6e-4f48-87ff-e233b79f8fdd

	measure 'Cal Overdue' =
			CALCULATE(COUNTROWS('Maintenance_Schedule'),
			'Service_Type'[is_type_calibration]= 1,
			'Maintenance_Schedule'[date_calculated_service_due]<TODAY(),
			ISBLANK('Maintenance_Schedule'[Date_Service_Completed])
			)
		formatString: 0
		lineageTag: be54aa55-318a-4de6-b774-b35af51216a3

	measure 'Main Within 30 days' =
			
			CALCULATE(
			    COUNTROWS('Maintenance_Schedule'),
			    'Maintenance_Schedule'[date_calculated_service_due]>= TODAY(),
			    'Maintenance_Schedule'[date_calculated_service_due]<= TODAY() + 30,
			    'Service_Type'[is_type_calibration]= 0
			)
		formatString: 0
		lineageTag: 86f4d42f-b780-4db8-8abe-2c9a8486d763

	measure 'Main Within 60 days' =
			
			CALCULATE(
			    COUNTROWS('Maintenance_Schedule'),
			    'Maintenance_Schedule'[date_calculated_service_due]> TODAY() +30,
			    'Maintenance_Schedule'[date_calculated_service_due]<= TODAY() + 60,
			    'Service_Type'[is_type_calibration]= 0
			)
		formatString: 0
		lineageTag: eb889561-6da8-4c3c-88af-28cd08c0cbb2

	measure 'Main Within 90 days' =
			
			CALCULATE(
			    COUNTROWS('Maintenance_Schedule'),
			    'Maintenance_Schedule'[date_calculated_service_due]> TODAY() + 60,
			    'Maintenance_Schedule'[date_calculated_service_due]<= TODAY() + 90,
			    'Service_Type'[is_type_calibration]= 0
			)
		formatString: 0
		lineageTag: 20f696e0-1bb7-40ff-8902-0413fb648287

	measure Space = BLANK()
		formatString: 0
		lineageTag: 51ee2f12-badc-4087-aabe-b4f84fa79f9c

	measure 'Total Calibration' =
			CALCULATE(COUNTROWS('Maintenance_Schedule'),
			Service_Type[is_type_calibration]=1)
		formatString: 0
		lineageTag: 4bc39a44-9d34-4cdb-881f-64d916b7ad24

	measure 'Total Maintenance' =
			CALCULATE(COUNT('Maintenance_Schedule'[id]),
			Service_Type[is_type_calibration]=0)
		formatString: 0
		lineageTag: 12c5eab8-c0a0-46d8-8888-e2df929e801e

	measure 'Main Overdue' =
			CALCULATE(COUNTROWS('Maintenance_Schedule'),
			'Maintenance_Schedule'[date_calculated_service_due]<TODAY(),
			ISBLANK('Maintenance_Schedule'[Date_Service_Completed]),
			'Service_Type'[is_type_calibration]= 0)
		formatString: 0
		lineageTag: 3dd077d8-ac4b-4103-a987-bf03067408f0

	measure 'Due Count' = CALCULATE(COUNTROWS('Maintenance_Schedule'), NOT ISBLANK(Maintenance_Schedule[date_calculated_service_due]))
		formatString: 0
		lineageTag: e7ff1c33-4a17-4f5e-a1d0-ab0cc00b765b

	measure 'Completed Count' = ```
			CALCULATE(COUNTROWS('Maintenance_Schedule'), USERELATIONSHIP('Date'[Date],'Maintenance_Schedule'[Date_Service_Completed]), NOT ISBLANK('Maintenance_Schedule'[Date_Service_Completed]))
			
			```
		formatString: 0
		lineageTag: f6c4cdd9-83a2-4206-9167-fb23c3300827

	measure 'Date Service Completed Count' = CALCULATE(COUNTROWS('Maintenance_Schedule'), NOT ISBLANK('Maintenance_Schedule'[Date_Service_Completed]))
		formatString: 0
		lineageTag: 47ca2581-ed7b-452c-af3d-78506a4b9b16

	measure 'Eq Overdue' =
			
			CALCULATE(
			    DISTINCTCOUNT('Equipment'[id]),
			    'Service_Type'[is_type_calibration] = 1,
			    'Maintenance_Schedule'[date_calculated_service_due] < TODAY(),
			    ISBLANK('Maintenance_Schedule'[Date_Service_Completed])
			)
		formatString: 0
		lineageTag: 25afc5b5-336b-4616-8721-dfec111c1f7a

