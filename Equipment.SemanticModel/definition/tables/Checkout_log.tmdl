	column 'Days Late Being Returned' =
			
			IF (
			    NOT( ISBLANK('Checkout_log'[date_of_check_in]) ) &&
			    'Checkout_log'[date_of_check_in] > 'Checkout_log'[date_estimated_checkin],
			    DATEDIFF (
			        'Checkout_log'[date_estimated_checkin],
			        'Checkout_log'[date_of_check_in],
			        DAY
			    )
			)
		formatString: 0
		lineageTag: ce92edcf-6cb1-494c-b682-592e1096a87e
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Days Checked Out Too Long' =
			
			IF (
			    ISBLANK('Checkout_log'[date_of_check_in]) &&
			    'Checkout_log'[date_estimated_checkin]< TODAY() ,
			    DATEDIFF (
			        'Checkout_log'[date_estimated_checkin],
			        TODAY(),
			        DAY),
			        BLANK()
			    )
		formatString: 0
		lineageTag: 6801591e-7f88-47af-93fa-bb094fc93913
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	partition Checkout_log = m
		mode: import
		source =
				let
				    Source = PowerPlatform.Dataflows(null),
				    Workspaces = Source{[Id="Workspaces"]}[Data],
				    Workspace = Workspaces{[workspaceId=getWorkspaceUUID ()]}[Data],
				    Dataflow = Workspace {[dataflowId=getDataflowUUID ("Equipment_DF_Test")]}[Data],
				    #"trutesta_equipment equipment_checkout_log_" = Dataflow{[entity="Checkout_Log",version=""]}[Data]
				in
				    #"trutesta_equipment equipment_checkout_log_"

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

