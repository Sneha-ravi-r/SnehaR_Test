table Checkout_log
	lineageTag: 27372c27-2b17-48a4-a9c3-6553c812c35b

	measure 'Checked Out Too Long' =
			
			CALCULATE(
			    COUNTROWS('Checkout_log'),
			    'Checkout_log'[Days Checked Out Too Long] > 0
			)
		formatString: 0
		lineageTag: 33cc2d3f-1b00-4ebb-a41b-a5d9adc36856

	measure 'Late Being Returned' =
			
			CALCULATE(
			    COUNTROWS(Checkout_log),
			    'Checkout_log'[Days Late Being Returned] > 0
			)
		formatString: 0
		lineageTag: 5027e087-605b-4ea0-b2e5-948b5dd33353

	measure 'Returned Items 2' = CALCULATE(COUNTROWS('Checkout_log'), NOT ISBLANK( Checkout_log[date_of_check_in]))
		formatString: 0
		lineageTag: 9adfb053-be1f-4b32-97a1-6a33f2556132

